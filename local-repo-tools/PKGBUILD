pkgname=local-repo-tools
pkgver=1.0
pkgrel=1
pkgdesc="Manage local pacman repos"
arch=('any')
url="https://github.com/jgthomas/scripts"
license=('GPL3')
depends=('libarchive')
source=("repo-clean" "repo-db-clean" "repo-files-clean")
md5sums=('SKIP' 'SKIP' 'SKIP')


package() {

        install -d "$pkgdir/usr/bin"

        install -m755 "$srcdir/repo-clean" "$pkgdir/usr/bin/repo-clean"
        install -m755 "$srcdir/repo-db-clean" "$pkgdir/usr/bin/repo-db-clean"
        install -m755 "$srcdir/repo-files-clean" "$pkgdir/usr/bin/repo-files-clean"

}


